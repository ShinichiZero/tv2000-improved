<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Focused / selected: bright gold fill -->
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#C9A84C"/>
            <corners android:radius="10dp"/>
            <stroke android:width="2dp" android:color="#E0C06A"/>
        </shape>
    </item>

    <!-- Pressed -->
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#A07830"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>

    <!-- Default: dim gold border -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#22C9A84C"/>
            <stroke android:width="2dp" android:color="#C9A84C"/>
            <corners android:radius="10dp"/>
        </shape>
    </item>
</selector>
