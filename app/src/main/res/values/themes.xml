<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.TV2000" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/background</item>
        <item name="android:statusBarColor">@color/background</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:colorAccent">@color/gold</item>
        <!-- TV: no focus highlight ring from system — we draw our own -->
        <item name="android:textColorHighlight">@color/gold_dim</item>
    </style>
</resources>
